{
  "name": "solid-web-components-ui",
  "private": false,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && node scripts/organize-css.js",
    "build:analyze": "tsc && vite build && node scripts/organize-css.js && npx vite preview --outDir dist",
    "size": "node scripts/size-report.js",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "publish": "npm run build && npm publish",
    "test": "vitest"
  },
  "dependencies": {
    "solid-js": "^1.8.17"
  },
  "devDependencies": {
    "@testing-library/dom": "^9.3.4",
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.56.0",
    "eslint-plugin-solid": "^0.13.1",
    "jsdom": "^24.0.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.0",
    "vite-plugin-dts": "^3.7.3",
    "vite-plugin-solid": "^2.10.2",
    "vitest": "^1.2.2"
  },
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./components/Button": {
      "import": "./dist/components/Button.es.js",
      "require": "./dist/components/Button.cjs.js",
      "types": "./dist/components/Button/index.d.ts"
    },
    "./components/Button/style.css": "./dist/components/Button/style.css",
    "./icons": {
      "import": "./dist/icons.es.js",
      "require": "./dist/icons.cjs.js",
      "types": "./dist/icons/index.d.ts"
    },
    "./dist/assets/*": "./dist/assets/*"
  },
  "files": [
    "dist",
    "!dist/stats.html",
    "!dist/stats-*.html"
  ]
}
